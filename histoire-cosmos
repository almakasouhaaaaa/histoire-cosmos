<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Notre histoire — Cosmos</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;800&display=swap" rel="stylesheet">
<style>

:root{
  --white:#FFFFFF;
  --bg:#F8FAF9;

  --vert1:#004C3E;
  --vert2:#1B685B;
  --jaune:#FEEC33;
  --bleu:#87C9C2;

  --line:#DDE7E5;

  --ink:#004C3E;
  --ink-soft:#4E6A64;

  --font-display:'Outfit', sans-serif;
  --font-body:'Outfit', sans-serif;
}

*{margin:0;padding:0;box-sizing:border-box;}

body{
  font-family:var(--font-body);
  background:var(--white);
  color:var(--ink);
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}

a{color:inherit;text-decoration:none;}
img{max-width:100%;display:block;}

.wrap{
  max-width:1060px;
  margin:0 auto;
  padding:0 32px;
}

/* ===================== ANIMATIONS & REVEALS ===================== */

.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s cubic-bezier(0.215, 0.61, 0.355, 1), transform 0.8s cubic-bezier(0.215, 0.61, 0.355, 1);
  will-change: opacity, transform;
}

.reveal.in-view {
  opacity: 1;
  transform: translateY(0);
}

/* Delays pour les grilles d'éléments */
.pilier:nth-child(1) { transition-delay: 0.1s; }
.pilier:nth-child(2) { transition-delay: 0.25s; }
.pilier:nth-child(3) { transition-delay: 0.4s; }

.r-item:nth-child(1) { transition-delay: 0.1s; }
.r-item:nth-child(2) { transition-delay: 0.2s; }
.r-item:nth-child(3) { transition-delay: 0.3s; }
.r-item:nth-child(4) { transition-delay: 0.4s; }

/* Animation d'introduction immédiate pour le Hero */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(24px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===================== HERO ===================== */

.hero{
  padding:140px 0 100px;
  text-align:center;
  background:var(--vert1);
  color:white;
}

.hero-eyebrow{
  display:inline-flex;
  align-items:center;
  gap:10px;
  font-size:12.5px;
  letter-spacing:0.16em;
  text-transform:uppercase;
  color:var(--bleu);
  margin-bottom:34px;
  font-weight:600;
  opacity: 0;
  animation: fadeInUp 0.8s cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
  animation-delay: 0.15s;
}
.hero-eyebrow span{
  width:6px;height:6px;border-radius:50%;
  background:var(--jaune);
  display:inline-block;
}

.hero h1{
  font-family:var(--font-display);
  font-weight:800;
  font-size:clamp(38px,6.4vw,68px);
  line-height:1.12;
  text-transform: uppercase;
  letter-spacing:-0.01em;
  max-width:760px;
  margin:0 auto;
  opacity: 0;
  animation: fadeInUp 0.8s cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
  animation-delay: 0.3s;
}
.hero h1 em{
 color:var(--jaune);
 font-style:normal;
}

.hero-sub{
  max-width:580px;
  margin:28px auto 0;
  font-size:18px;
  line-height:1.65;
  color:rgba(255, 255, 255, 0.85);
  opacity: 0;
  animation: fadeInUp 0.8s cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
  animation-delay: 0.45s;
}

.hero-tags{
  display:flex;
  justify-content:center;
  gap:10px;
  margin-top:44px;
  flex-wrap:wrap;
  opacity: 0;
  animation: fadeInUp 0.8s cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
  animation-delay: 0.6s;
}
.hero-tag{
 background:rgba(255,255,255,0.08);
 border:1px solid rgba(255,255,255,0.2);
 color:white;
 font-weight:600;
 padding:8px 18px;
 border-radius:4px;
 font-size:14px;
 text-transform: uppercase;
 letter-spacing: 0.05em;
}

.hero-photo{
  margin-top:64px;
  height:1px;
  background:linear-gradient(90deg, transparent, var(--line) 20%, var(--line) 80%, transparent);
}

/* ===================== CONSTAT ===================== */

.constat{
  padding:96px 0 88px;
}

.eyebrow-row{
  display:flex;
  align-items:center;
  gap:12px;
  font-size:13px;
  font-weight:700;
  letter-spacing:0.13em;
  text-transform:uppercase;
  color:var(--vert2);
  margin-bottom:30px;
}
.eyebrow-row::before{
  content:"";
  width:24px;height:2px;
  background:var(--vert2);
}
.eyebrow-row.center{justify-content:center;}
.eyebrow-row.center::before{display:none;}

.constat-body{
  width: 100%;
  margin-bottom: 20px;
}

.constat-body p{
  font-size:16.5px;
  line-height:1.8;
  color:var(--ink-soft);
  margin-bottom:20px;
}
.constat-body p:last-child {
  margin-bottom: 0;
}
.constat-body strong{
  color:var(--ink);
  font-weight:700;
}

.piliers{
  margin-top:84px;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  border-top:2px solid var(--line);
}

.pilier{
  padding:40px 24px 0;
  border-right:1px solid var(--line);
  transition: opacity 0.8s cubic-bezier(0.215, 0.61, 0.355, 1), transform 0.8s cubic-bezier(0.215, 0.61, 0.355, 1);
}
.pilier:last-child{border-right:none;}
.pilier-tag{
  font-family:var(--font-display);
  font-weight:800;
  font-size:24px;
  color:var(--bleu);
  margin-bottom:12px;
}
.pilier h3{
  font-family:var(--font-body);
  font-weight:800;
  text-transform: uppercase;
  font-size:18px;
  margin-bottom:12px;
  letter-spacing: 0.05em;
}
.pilier p{
  font-size:15px;
  line-height:1.65;
  color:var(--ink-soft);
}

/* ===================== TIMELINE ===================== */

.timeline-section{
  background:var(--bg);
  padding:100px 0 120px;
  border-top:1px solid var(--line);
  border-bottom:1px solid var(--line);
}

.timeline-head{
  text-align:center;
  margin-bottom:84px;
}
.timeline-head h2{
  font-family:var(--font-display);
  font-weight:800;
  text-transform: uppercase;
  font-size:clamp(32px,5vw,54px);
  line-height:1.1;
  max-width:720px;
  margin:0 auto;
}
.timeline-head h2 em{
  font-style:normal;
  color:var(--vert2);
}

.timeline{
  position:relative;
  max-width:840px;
  margin:0 auto;
}

.timeline-spine{
  position:absolute;
  left:50%;
  top:4px;
  bottom:4px;
  width:2px;
  background:var(--line);
  transform:translateX(-50%);
}

.tl-item {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 48px 1fr;
  align-items: start;
  opacity: 0;
  transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  will-change: opacity, transform;
}

/* Effet de slide directionnel selon la parité */
@media (min-width: 861px) {
  .tl-item:nth-child(odd) {
    transform: translateX(-40px);
  }
  .tl-item:nth-child(even) {
    transform: translateX(40px);
  }
}
@media (max-width: 860px) {
  .tl-item {
    transform: translateY(30px);
  }
}

.tl-item.in-view {
  opacity: 1;
  transform: translate(0) !important;
}

.tl-card{
  padding:20px 30px;
  margin:20px 0;
  background: white;
  border: 1px solid var(--line);
  border-radius: 4px;
  transition: box-shadow 0.3s ease;
}
.tl-card:hover {
  box-shadow: 0 10px 30px rgba(0, 76, 62, 0.05);
}

.tl-item:nth-child(odd) .tl-card{grid-column:1;justify-self:end;text-align:right;}
.tl-item:nth-child(even) .tl-card{grid-column:3;justify-self:start;text-align:left;}

.tl-year{
  font-family:var(--font-display);
  font-weight:800;
  font-size:36px;
  color:var(--vert1);
  margin-bottom:8px;
}
.tl-item:nth-child(even) .tl-year{color:var(--vert2);}

.tl-card h3{
  font-family:var(--font-body);
  font-weight:800;
  text-transform: uppercase;
  font-size:18px;
  margin-bottom:12px;
  line-height:1.35;
  color:var(--ink);
  letter-spacing: 0.03em;
}

.tl-card p{
  font-size:15px;
  line-height:1.7;
  color:var(--ink-soft);
}
.tl-card ul{list-style:none;margin-top:12px;text-align: left;}
.tl-item:nth-child(odd) .tl-card ul { display: inline-block; text-align: right; }
.tl-card li{
  font-size:14.5px;
  line-height:1.7;
  color:var(--ink-soft);
  margin-bottom:8px;
}
.tl-card li strong{color:var(--ink);font-weight:600;}

.tl-node-col{
  grid-column:2;
  display:flex;
  justify-content:center;
  padding-top:34px;
}
.tl-node{
  width:16px;height:16px;
  border-radius:50%;
  background:var(--jaune);
  border:4px solid var(--vert1);
  box-shadow:0 0 0 2px var(--line);
  position:relative;
  z-index:2;
  transform: scale(0);
  transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  transition-delay: 0.2s;
}
.tl-item:nth-child(even) .tl-node{background:var(--bleu); border-color: var(--vert2);}

.tl-item.in-view .tl-node {
  transform: scale(1.15);
}

.tl-final{
  text-align:center;
  margin-top:84px;
  padding-top:60px;
  border-top:2px solid var(--line);
}
.tl-final blockquote{
  font-family:var(--font-display);
  font-weight:500;
  font-size:clamp(18px,2.5vw,22px);
  line-height:1.6;
  max-width:760px;
  margin:0 auto;
  color:var(--ink);
}
.tl-final blockquote .name{
  font-style:normal;
  font-weight:800;
  color:var(--vert2);
}

/* ===================== REASSURANCE ===================== */

.reassurance{
  padding:60px 0;
  background: var(--bg);
  border-bottom: 1px solid var(--line);
}
.reassurance-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
}
.r-item{
  text-align:center;
  padding:0 16px;
  border-right:1px solid var(--line);
}
.r-item:last-child{border-right:none;}
.r-mark{
  font-family:var(--font-display);
  font-weight:800;
  font-size:24px;
  color:var(--vert1);
  margin-bottom:8px;
}
.r-item h4{
  font-size:15px;
  font-weight:700;
  text-transform: uppercase;
  margin-bottom:6px;
}
.r-item p{
  font-size:13px;
  color:var(--ink-soft);
  line-height:1.5;
}

/* ===================== CTA ===================== */

.cta{
  padding:100px 0;
  text-align:center;
  background: var(--jaune);
}
.cta h2{
  font-family:var(--font-display);
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:-0.02em;
  font-size:clamp(32px,5vw,52px);
  line-height:1.1;
  max-width:560px;
  margin:0 auto 16px;
  color: var(--vert1);
}
.cta p{
  font-size:18px;
  color:var(--ink);
  max-width:460px;
  margin:0 auto 32px;
  line-height:1.6;
}
.cta-btn{
  display:inline-flex;
  align-items:center;
  background:var(--vert1);
  color:var(--jaune);
  padding:18px 40px;
  border-radius:0px; /* Style brut Cosmos */
  font-weight:700;
  font-size:16px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  transition: background 0.25s ease, transform 0.25s ease;
}
.cta-btn:hover{background:var(--black); color: white; transform:translateY(-2px);}

/* ===================== RESPONSIVE ===================== */

@media (max-width:860px){
  .piliers{grid-template-columns:1fr;}
  .pilier{border-right:none;border-bottom:1px solid var(--line);padding-bottom:24px;margin-bottom:24px;}
  .pilier:last-child{border-bottom:none;margin-bottom:0;}
  .reassurance-grid{grid-template-columns:repeat(2,1fr);row-gap:36px;}
  .r-item:nth-child(odd){border-right:1px solid var(--line);}
  .r-item:nth-child(2),.r-item:nth-child(4){border-right:none;}

  .tl-item{grid-template-columns:30px 1fr;}
  .tl-node-col{grid-column:1;padding-top:30px;}
  .tl-item:nth-child(odd) .tl-card,
  .tl-item:nth-child(even) .tl-card{
    grid-column:2;
    justify-self:stretch;
    text-align:left;
    margin:18px 0;
    padding:8px 0 8px 4px;
  }
  .timeline-spine{left:15px;}
}
</style>
</head>
<body>

<section class="hero">
  <div class="wrap">
    <p class="hero-eyebrow"><span></span>Notre histoire<span></span></p>
    <h1>Notre histoire</h1>
    <p class="hero-sub">D'une cuisine à la première entreprise de shots bio en France : l'histoire d'une conviction simple devenue un succès.</p>
    <div class="hero-tags">
      <span class="hero-tag">Bio &amp; certifié</span>
      <span class="hero-tag">Fabriqué en France</span>
      <span class="hero-tag">Vu sur M6</span>
    </div>
  </div>
</section>

<section class="constat reveal">
  <div class="wrap">
    <p class="eyebrow-row">Le constat</p>
    <div class="constat-body">
      <p>Tout commence avec <strong>Léo Ravillion</strong>. Travaillant dans l'univers de l'alimentation biologique, il est profondément marqué par les enjeux environnementaux et le respect de la biodiversité.</p>
      <p>Grand amateur de boissons, il fait pourtant un constat simple : la majorité des produits sur le marché sont composés d'un immense pourcentage d'eau, de beaucoup de sucre, et de très peu d'ingrédients réellement intéressants pour la santé.</p>
      <p>C'est là que naît son ambition : <strong>inverser la tendance</strong>. Pourquoi ne pas réduire l'eau et le sucre pour proposer un format ultra-concentré en matières premières de haute qualité ? Le concept du shot était né, avec trois valeurs clés :</p>
    </div>

    <div class="piliers">
      <div class="pilier reveal">
        <p class="pilier-tag">01</p>
        <h3>Le goût</h3>
        <p>Un vrai plaisir en bouche grâce à des recettes travaillées et testées.</p>
      </div>
      <div class="pilier reveal">
        <p class="pilier-tag">02</p>
        <h3>L'efficacité</h3>
        <p>Des bénéfices pour la santé réels, approuvés et sans compromis.</p>
      </div>
      <div class="pilier reveal">
        <p class="pilier-tag">03</p>
        <h3>L'engagement</h3>
        <p>Des produits bio, peu transformés et éco-responsables, de la matière première jusqu'à la bouteille en verre.</p>
      </div>
    </div>
  </div>
</section>

<section class="timeline-section">
  <div class="wrap">
    <div class="timeline-head reveal">
      <p class="eyebrow-row center"></p>
      <h2>Les grandes étapes de Cosmos</h2>
    </div>

    <div class="timeline">
      <div class="timeline-spine"></div>

      <div class="tl-item">
        <div class="tl-card">
          <p class="tl-year">2016</p>
          <h3>De la cuisine aux premiers défis</h3>
          <p>Léo commence à formuler ses premières recettes directement dans sa cuisine. Pour passer à l'échelle supérieure, il démarche les industriels de la boisson mais aucun n'est équipé pour conditionner les formats shots. Léo décide alors de créer sa propre structure, de concevoir des machines sur mesure et d'entamer 4 ans de recherche et développement (un travail d'innovation d'ailleurs soutenu par la French Tech).</p>
        </div>
        <div class="tl-node-col"><div class="tl-node"></div></div>
      </div>

      <div class="tl-item">
        <div class="tl-card">
          <p class="tl-year">2020</p>
          <h3>Le grand lancement</h3>
          <ul>
            <li><strong>Été 2020 :</strong> Après des mois de retard liés au Covid-19, les premiers shots sortent enfin et s'implantent dans des coffee-shops, restaurants et salles de sport.</li>
            <li><strong>Octobre 2020 :</strong> Fermeture administrative des points de vente par l'État. Au lieu d'abandonner, l'équipe choisit de pivoter : elle repart en R&D pour concevoir une autre version du produit, plus stable et parfaitement adaptée aux exigences des réseaux de magasins bio.</li>
          </ul>
        </div>
        <div class="tl-node-col"><div class="tl-node"></div></div>
      </div>

      <div class="tl-item">
        <div class="tl-card">
          <p class="tl-year">2021 – 2022</p>
          <h3>Les pionniers du réseau bio</h3>
          <p>Cosmos s'impose comme le premier fabricant de shots en France. Les produits intègrent les enseignes nationales de référence : So.bio et Bio c'Bon en 2021, suivis de Naturalia en 2022.</p>
        </div>
        <div class="tl-node-col"><div class="tl-node"></div></div>
      </div>

      <div class="tl-item">
        <div class="tl-card">
          <p class="tl-year">2023</p>
          <h3>Création de l'usine et montée du succès</h3>
          <p>Création de l'usine automatisée de la marque à Marseille pour maîtriser la fabrication. Les shots intègrent le réseau Biocoop et se vendent désormais par millions.</p>
        </div>
        <div class="tl-node-col"><div class="tl-node"></div></div>
      </div>

      <div class="tl-item">
        <div class="tl-card">
          <p class="tl-year">2025</p>
          <h3>Le passage à la télévision</h3>
          <p>Après des années de développement rigoureux pour obtenir le produit parfait, Cosmos décide de se faire connaître du grand public. En mars 2025, Léo participe à l’émission « Qui veut être mon associé ? » sur M6 face à plus de 2 millions de téléspectateurs, permettant d'intégrer un nouvel associé pour structurer cette forte croissance.</p>
        </div>
        <div class="tl-node-col"><div class="tl-node"></div></div>
      </div>

      <!-- 2026 -->
      <div class="tl-item">
        <div class="tl-card">
          <p class="tl-year">2026</p>
          <h3>Le présent et l'avenir</h3>
          <p>Aujourd'hui, l'équipe continue de s'agrandir avec un nouvel objectif de taille pour cette année : le déploiement de la gamme en pharmacie.</p>
        </div>
        <div class="tl-node-col"><div class="tl-node"></div></div>
      </div>

    </div>

    <div class="tl-final reveal">
      <blockquote>Si Cosmos est aujourd'hui le pionnier incontesté du shot en France, c'est avant tout grâce à la persévérance de Léo. Il a su transformer une idée en une véritable ligne de produits qui explose sur le marché.</blockquote>
    </div>
  </div>
</section>

<section class="reassurance">
  <div class="wrap">
    <div class="reassurance-grid">
      <div class="r-item reveal">
        <p class="r-mark">FR</p>
        <h4>Fabrication locale</h4>
        <p>Dans notre propre usine marseillaise</p>
      </div>
      <div class="r-item reveal">
        <p class="r-mark">BIO</p>
        <h4>100% Bio</h4>
        <p>Certifié et sourcé de manière éco-responsable</p>
      </div>
      <div class="r-item reveal">
        <p class="r-mark">✓</p>
        <h4>Efficacité pure</h4>
        <p>Des bénéfices ciblés et validés scientifiquement</p>
      </div>
      <div class="r-item reveal">
        <p class="r-mark">01</p>
        <h4>Pionnier</h4>
        <p>Le tout premier créateur de shots en France</p>
      </div>
    </div>
  </div>
</section>

<section class="cta reveal">
  <div class="wrap">
    <h2>Goûtez à l'essentiel.</h2>
    <p>Le concentré de matières premières de haute qualité, dans chaque bouteille.</p>
    <a href="#" class="cta-btn">Découvrir nos shots →</a>
  </div>
</section>

<script>
// Sélection de tous les éléments à animer
const animateElements = document.querySelectorAll('.reveal, .tl-item');

// Configuration de l'observateur d'intersection
const obs = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('in-view');
      // On arrête d'observer une fois l'élément apparu pour optimiser les performances
      obs.unobserve(entry.target);
    }
  });
}, {
  threshold: 0.12, // Déclenche un peu avant que l'élément entier soit visible
  rootMargin: "0px 0px -40px 0px"
});

// Activation de l'observation sur chaque élément
animateElements.forEach(el => obs.observe(el));
</script>

</body>
</html>
